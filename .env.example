# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Apple (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=keys/apple.p8

# Session (must be at least 32 chars in production)
SESSION_SECRET=

# Server (local dev only — Vercel manages these in production)
PORT=3001
BASE_URL=http://localhost:3001
NODE_ENV=development

# Database
MONGODB_URI=

# PostHog analytics
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# Cloudflare R2 image storage
# Omit CDN_URL for local dev — images save to public/uploads/ instead
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
CDN_URL=
